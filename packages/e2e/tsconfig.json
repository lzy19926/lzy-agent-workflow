{
  // =========================================================================
  // TypeScript 编译器配置
  // 用于 VideoMemo E2E 测试项目
  //
  // @see https://www.typescriptlang.org/tsconfig
  // =========================================================================
  "compilerOptions": {
    // -----------------------------------------------------------------------
    // 基本编译选项
    // -----------------------------------------------------------------------

    // 编译目标：生成 ES2022 标准的 JavaScript 代码
    // ES2022 支持类字段、顶层 await、Promise.allSettled 等特性
    "target": "ES2022",

    // 模块系统：使用 ESNext（最新的 ECMAScript 模块）
    // 支持动态 import()、top-level await 等
    "module": "ESNext",

    // 包含的库文件
    // - ES2022: ES2022 标准库（Promise、Map、Set 等）
    // - DOM: 浏览器 DOM API（document、window、Element 等）
    // - DOM.Iterable: 可迭代的 DOM 集合（NodeList、HTMLCollection 等）
    "lib": ["ES2022", "DOM", "DOM.Iterable"],

    // 模块解析策略：使用 bundler 模式
    // 适用于现代打包工具（Vite、Rollup、esbuild 等）
    // 允许使用 .js 扩展名导入 TypeScript 文件
    "moduleResolution": "bundler",

    // -----------------------------------------------------------------------
    // 类型定义
    // -----------------------------------------------------------------------

    // 包含的类型定义文件
    // - node: Node.js 全局类型（process、__dirname 等）
    // - @playwright/test: Playwright 测试框架类型
    "types": ["node", "@playwright/test"],

    // -----------------------------------------------------------------------
    // 严格模式选项
    // -----------------------------------------------------------------------

    // 启用所有严格类型检查选项
    // 包括 noImplicitAny、strictNullChecks、strictFunctionTypes 等
    "strict": true,

    // -----------------------------------------------------------------------
    // 互操作性选项
    // -----------------------------------------------------------------------

    // 允许从没有默认导出的模块导入
    // 使得可以这样导入 CommonJS 模块：import express from 'express'
    "esModuleInterop": true,

    // 跳过声明文件的类型检查（node_modules 中的 .d.ts 文件）
    // 加速编译，减少不必要的类型错误
    "skipLibCheck": true,

    // 对文件名的 casing 一致性进行强制检查
    // 避免在大小写不敏感系统（Windows/macOS）上出现的问题
    "forceConsistentCasingInFileNames": true,

    // 允许导入 JSON 模块
    // 支持 import config from './config.json' 语法
    "resolveJsonModule": true,

    // 要求每个文件单独编译，不依赖上下文
    // 与 ES 模块和打包工具兼容
    "isolatedModules": true,

    // -----------------------------------------------------------------------
    // 输出选项
    // -----------------------------------------------------------------------

    // 不生成输出文件（.js、.d.ts）
    // Playwright 直接运行 TypeScript 源文件，无需预编译
    "noEmit": true,

    // JSX 转换模式：使用 react-jsx（React 17+ 新 JSX 转换）
    // 无需导入 React 即可使用 JSX
    "jsx": "react-jsx",

    // -----------------------------------------------------------------------
    // 路径映射
    // -----------------------------------------------------------------------

    // 基础路径：当前配置文件所在目录
    "baseUrl": ".",

    // 路径别名配置
    // 简化导入路径，无需使用相对路径 ../../../
    "paths": {
      // @/ 映射到 src/ 目录（如果未来添加 src 目录）
      "@/*": ["src/*"],
      // @fixtures/ 映射到 fixtures/ 目录（测试 fixtures 和 POM）
      "@fixtures/*": ["fixtures/*"],
      // @utils/ 映射到 utils/ 目录（工具函数）
      "@utils/*": ["utils/*"],
      // @tests/ 映射到 tests/ 目录（测试用例）
      "@tests/*": ["tests/*"]
    }
  },

  // =========================================================================
  // 包含的文件
  // =========================================================================

  // 指定 TypeScript 检查的文件
  // **/*.ts: 所有 TypeScript 文件
  // **/*.tsx: 所有 TSX 文件（含 JSX 的 TypeScript）
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],

  // =========================================================================
  // 排除的文件
  // =========================================================================

  // 指定 TypeScript 忽略的文件和目录
  "exclude": [
    // node_modules: 依赖包目录，由 skipLibCheck 处理
    "node_modules",
    // playwright-report: 测试报告输出目录
    "playwright-report",
    // test-results: 测试结果（截图、视频等）输出目录
    "test-results"
  ]
}
