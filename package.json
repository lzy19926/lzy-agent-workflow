{
  "name": "lzy-agent-workflow",
  "version": "1.1.0",
  "description": "一站式AI集成工作台",
  "private": true,
  "scripts": {
    "dev:backend": "pnpm --filter @videomemo/backend dev",
    "dev:frontend": "pnpm --filter @videomemo/frontend dev",
    "build:core": "pnpm --filter @videomemo/core build",
    "build:backend": "pnpm --filter @videomemo/backend build",
    "build:frontend": "pnpm --filter @videomemo/frontend build",
    "build": "pnpm build:core && pnpm build:backend && pnpm build:frontend",
    "start:backend": "pnpm --filter @videomemo/backend start",
    "clean": "pnpm -r clean"
  },
  "keywords": [
    "video",
    "transcribe",
    "bilibili"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "axios": "^1.6.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  }
}